// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Perfil {
  COLABORADOR
  GESTOR
  FINANCEIRO
  ADMIN
}

enum ReimbursementStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  REJEITADO
  PAGO
  CANCELADO
}

enum HistoryAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  CANCELED
}

model User {
  id             String          @id @default(uuid())
  nome           String
  email          String          @unique
  senha          String
  perfil         Perfil
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt

  refreshTokens RefreshToken[] 
  reimbursements Reimbursement[]
  histories      History[]
}

model Category {
  id             String          @id @default(uuid())
  nome           String          @unique
  ativo          Boolean         @default(true)
  valorMaximo    Float?
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt
  deletadoEm     DateTime?
  reimbursements Reimbursement[]
}

model Reimbursement {
  id                    String             @id @default(uuid())
  solicitanteId         String
  categoriaId           String
  descricao             String
  valor                 Float
  dataDespesa           DateTime
  status                ReimbursementStatus
  justificativaRejeicao String?
  criadoEm              DateTime           @default(now())
  atualizadoEm          DateTime           @updatedAt
  deletadoEm            DateTime?

  solicitante           User               @relation(fields: [solicitanteId], references: [id])
  categoria             Category           @relation(fields: [categoriaId], references: [id])
  attachments           Attachment[]
  histories             History[]
}

model Attachment {
  id            String        @id @default(uuid())
  solicitacaoId String
  nomeArquivo   String
  urlArquivo    String
  tipoArquivo   String
  criadoEm      DateTime      @default(now())

  solicitacao   Reimbursement @relation(fields: [solicitacaoId], references: [id])
}

model History {
  id            String        @id @default(uuid())
  solicitacaoId String
  usuarioId     String
  acao          HistoryAction
  observacao    String?
  criadoEm      DateTime      @default(now())

  solicitacao   Reimbursement @relation(fields: [solicitacaoId], references: [id])
  usuario       User          @relation(fields: [usuarioId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id])
  criadoEm  DateTime @default(now())
  expiraEm  DateTime
  revogado  Boolean  @default(false)
}

