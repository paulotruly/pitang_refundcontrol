# URL do banco de dados (SQLite para desenvolvimento)
DATABASE_URL="file:./dev.db"

# Chave secreta para JWT (gere uma string aleatória segura)
JWT_SECRET=sua_chave_secreta_jwt_aqui

# Chave secreta para refresh tokens (pode ser diferente do JWT_SECRET)
REFRESH_TOKEN_SECRET=sua_chave_secreta_refresh_aqui